<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/background_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvItemReporteTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_tipo"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tvItemReporteDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_descripcion"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="4dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_circle_avatar"/>

            <TextView
                android:id="@+id/tvItemReporteUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_usuario"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvItemReporteFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_fecha"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp"
            app:drawableStartCompat="@android:drawable/ic_menu_recent_history"
            android:drawablePadding="6dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvConfirmCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/confirmaciones_count"
                android:textSize="14sp"
                android:textColor="@color/primary"
                android:fontFamily="sans-serif-medium"/>

            <Button
                android:id="@+id/btnConfirmarReporte"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_confirmar"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>

