<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/background_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/viewEstadoIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/bg_circle_avatar"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvEmergenciaId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_id"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/tvEmergenciaUbic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_ubicacion"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"
                app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
                android:drawablePadding="6dp"/>

            <TextView
                android:id="@+id/tvEmergenciaFecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_fecha"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp"
                app:drawableStartCompat="@android:drawable/ic_menu_recent_history"
                android:drawablePadding="6dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvEmergenciaEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_estado"
            android:textSize="12sp"
            android:textColor="@color/primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_input_field"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"/>

    </LinearLayout>

</androidx.cardview.widget.CardView>

